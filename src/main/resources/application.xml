<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN"
        "http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>

    <bean id="customerManagement" class="se.yrgo.services.customers.CustomerManagementMockImpl"/>

    <bean id="diaryManagement" class="se.yrgo.services.diary.DiaryManagementServiceMockImpl"/>

    <bean id="callHandling" class="se.yrgo.services.calls.CallHandlingServiceImpl">
        <property name="customerManagementService" ref="customerManagement"/>
        <property name="diaryManagementService" ref="diaryManagement"/>
    </bean>


    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource"
          destroy-method="close">
        <property name="driverClassName" value="org.hsqldb.jdbc.JDBCDriver"/>
        <property name="url" value="jdbc:hsqldb:file:crmdb;shutdown=true"/>
        <property name="username" value="sa"/>
        <property name="password" value=""/>
    </bean>

    <bean id="jdbcTemplate" class="org.springframework.jdbc.core.JdbcTemplate">
        <constructor-arg ref="dataSource"/>
    </bean>

    <bean id="customerDao" class="se.yrgo.dataaccess.CustomerDaoJdbcTemplateImpl">
        <constructor-arg ref="jdbcTemplate"/>
    </bean>

</beans>
